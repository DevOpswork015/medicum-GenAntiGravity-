# ============================================================================
# API KEYS TEMPLATE
# ============================================================================
# Copy this file to `.env` and fill in your actual keys.
# NEVER commit the actual .env file to git.
# For GitHub Actions, add these as repository Secrets.
# ============================================================================

# ----- LLM / Script Generation -----
# Get a free Groq API key at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# ----- Visual Assets (all optional but recommended) -----
# Pexels: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here
# Pixabay: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your_pixabay_api_key_here
# Unsplash: https://unsplash.com/developers
UNSPLASH_API_KEY=your_unsplash_access_key_here

# ----- Trend Sources -----
# Reddit: https://www.reddit.com/prefs/apps (create a "script" app)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=trends-video-bot v1.0.0 by /u/your_reddit_username

# Twitter/X (optional - the pipeline works without it)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# ----- YouTube (for automatic uploads only; not needed for --dry-run) -----
# YouTube Data API v3 key from Google Cloud Console
YOUTUBE_API_KEY=your_youtube_developer_api_key_here
# Path to OAuth client secrets JSON (download from Google Cloud Console)
YOUTUBE_CLIENT_SECRETS_FILE=config/client_secrets.json
